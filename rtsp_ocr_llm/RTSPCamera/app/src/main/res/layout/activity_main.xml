<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#141414"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_icon_box"
                android:gravity="center">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_camera"
                    android:tint="#4CAF50"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CamStream"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvIpAddress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="● Connecting..."
                    android:textColor="#4CAF50"
                    android:textSize="13sp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvStatusBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● IDLE"
                android:textColor="#888888"
                android:textSize="12sp"
                android:background="@drawable/bg_status_badge"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"/>
        </LinearLayout>

        <!-- Camera Preview -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/previewCard"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#000000"
            app:cardElevation="0dp"
            android:layout_marginBottom="12dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextureView
                    android:id="@+id/textureView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>

                <TextView
                    android:id="@+id/tvCameraBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:layout_margin="10dp"
                    android:text="REAR"
                    android:textColor="#CCCCCC"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_preview_badge"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="5dp"/>
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Stream URL Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="STREAM URL"
                android:textColor="#666666"
                android:textSize="11sp"
                android:layout_marginBottom="10dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvUrl"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:text="Start stream to get URL"
                    android:textColor="#555555"
                    android:textSize="13sp"
                    android:fontFamily="monospace"
                    android:background="@drawable/bg_url_field"
                    android:paddingHorizontal="12dp"
                    android:gravity="center_vertical"
                    android:textIsSelectable="true"
                    android:singleLine="true"
                    android:ellipsize="middle"
                    android:layout_marginEnd="8dp"/>

                <ImageButton
                    android:id="@+id/btnCopyUrl"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:src="@drawable/ic_copy"
                    android:tint="#888888"
                    android:background="@drawable/bg_copy_btn"
                    android:padding="10dp"
                    android:contentDescription="Copy URL"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Settings Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginBottom="14dp">

            <!-- Camera Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="4dp">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_switch_camera"
                    android:tint="#888888"
                    android:background="@drawable/bg_icon_small"
                    android:padding="8dp"
                    android:layout_marginEnd="14dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Camera"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Select which camera to stream"
                        android:textColor="#666666"
                        android:textSize="12sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnRear"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="REAR"
                        android:textSize="11sp"
                        android:textColor="#FFFFFF"
                        android:background="@drawable/bg_toggle_selected"
                        android:paddingHorizontal="12dp"
                        android:stateListAnimator="@null"
                        android:layout_marginEnd="6dp"/>

                    <Button
                        android:id="@+id/btnFront"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="FRONT"
                        android:textSize="11sp"
                        android:textColor="#FFFFFF"
                        android:background="@drawable/bg_toggle_unselected"
                        android:paddingHorizontal="12dp"
                        android:stateListAnimator="@null"/>
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#252525"
                android:layout_marginVertical="12dp"/>

            <!-- Orientation Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="4dp">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_camera"
                    android:tint="#888888"
                    android:background="@drawable/bg_icon_small"
                    android:padding="8dp"
                    android:layout_marginEnd="14dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Orientation"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Landscape or Portrait stream"
                        android:textColor="#666666"
                        android:textSize="12sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnLandscape"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="LAND"
                        android:textSize="11sp"
                        android:textColor="#FFFFFF"
                        android:background="@drawable/bg_toggle_selected"
                        android:paddingHorizontal="12dp"
                        android:stateListAnimator="@null"
                        android:layout_marginEnd="6dp"/>

                    <Button
                        android:id="@+id/btnPortrait"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="PORT"
                        android:textSize="11sp"
                        android:textColor="#FFFFFF"
                        android:background="@drawable/bg_toggle_unselected"
                        android:paddingHorizontal="12dp"
                        android:stateListAnimator="@null"/>
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#252525"
                android:layout_marginVertical="12dp"/>

            <!-- Port Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="4dp">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_port"
                    android:tint="#888888"
                    android:background="@drawable/bg_icon_small"
                    android:padding="8dp"
                    android:layout_marginEnd="14dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Port"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RTSP server port number"
                        android:textColor="#666666"
                        android:textSize="12sp"/>
                </LinearLayout>

                <EditText
                    android:id="@+id/etPort"
                    android:layout_width="72dp"
                    android:layout_height="wrap_content"
                    android:text="8554"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:inputType="number"
                    android:gravity="end"
                    android:background="@drawable/bg_port_underline"
                    android:paddingVertical="6dp"
                    android:maxLength="5"
                    android:singleLine="true"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Start/Stop Button -->
        <Button
            android:id="@+id/btnStartStop"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="▶  Start Stream"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/bg_start_button"
            android:stateListAnimator="@null"
            android:layout_marginBottom="12dp"/>

        <!-- How to Connect Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_info"
                    android:tint="#666666"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HOW TO CONNECT"
                    android:textColor="#666666"
                    android:textSize="11sp"/>
            </LinearLayout>

            <!-- Step 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:text="1"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:background="@drawable/bg_step_number"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Connect your viewer device to the same Wi-Fi network"
                    android:textColor="#888888"
                    android:textSize="13sp"/>
            </LinearLayout>

            <!-- Step 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:text="2"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:background="@drawable/bg_step_number"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Open VLC → Media → Open Network Stream"
                    android:textColor="#888888"
                    android:textSize="13sp"/>
            </LinearLayout>

            <!-- Step 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:text="3"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:background="@drawable/bg_step_number"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Paste the RTSP URL shown above and press Play"
                    android:textColor="#888888"
                    android:textSize="13sp"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
